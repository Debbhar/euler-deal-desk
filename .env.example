# Copy to .env (or set in your host dashboard). All optional — unset = mock/skip.

# Core
PORT=4610
ALLOWED_DOMAINS=hcltech.com
# DB_PATH=/data/dealdesk.db          # point at a mounted disk to persist SQLite

# 1) HCLTech Azure / Entra ID SSO (OpenID Connect)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=https://your-host/api/auth/callback
# AZURE_ALLOWED_GROUP=

# 2) Salesforce — custom object Deal_Registration__c (username-password OAuth)
# SF_LOGIN_URL=https://login.salesforce.com
# SF_CLIENT_ID=
# SF_CLIENT_SECRET=
# SF_USERNAME=
# SF_PASSWORD=          # password + security token concatenated
# SF_OBJECT=Deal_Registration__c
# SF_FIELD_MAP={"Customer_Company__c":"company","TCV__c":"tcv"}

# 3) Email — Microsoft 365 / Graph (app-only Mail.Send; reuses the Entra app)
# MAIL_SENDER=dealdesk@hcltech.com
# MAIL_TO=dealdesk@hcltech.com,apac.dealdesk@hcltech.com

# Optional extra fan-out
# DEALDESK_WEBHOOK=https://hooks.zapier.com/...
